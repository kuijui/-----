.header {
  text-align: center;
  padding: 60rpx 20rpx 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA06B 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.form-item {
  margin-bottom: 40rpx;
}

.label {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.required {
  color: #ff4d4f;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea.short {
  min-height: 120rpx;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.style-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.style-item {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.style-item.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA06B 100%);
  color: #fff;
  transform: scale(1.05);
}

.length-options {
  display: flex;
  gap: 20rpx;
}

.length-item {
  flex: 1;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  transition: all 0.3s;
}

.length-item.active {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA06B 100%);
  color: #fff;
}

.length-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.length-desc {
  font-size: 22rpx;
  opacity: 0.8;
}

.action-area {
  padding: 0 20rpx 40rpx;
}

.action-area button {
  width: 100%;
}

.remaining-count {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.remaining-count .count {
  color: #FF6B9D;
  font-weight: bold;
  font-size: 32rpx;
}

.remaining-count .link {
  color: #FF6B9D;
  margin-left: 20rpx;
  text-decoration: underline;
}

.hot-topics {
  padding: 0 20rpx 180rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.topic-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.topic-tag {
  background: linear-gradient(135deg, #FFE5EE 0%, #FFF0E5 100%);
  color: #FF6B9D;
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
}
