.score-card {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA06B 100%);
  margin: 20rpx;
  padding: 40rpx;
  border-radius: 16rpx;
  text-align: center;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.score-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.score-value {
  font-size: 72rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.score-icon {
  font-size: 48rpx;
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.3;
}

.section {
  margin-bottom: 40rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.titles {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.title-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.title-item.selected {
  background: linear-gradient(135deg, #FFE5EE 0%, #FFF0E5 100%);
  border: 2rpx solid #FF6B9D;
}

.title-item radio {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.title-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  background: #f8f8f8;
  padding: 24rpx;
  border-radius: 12rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: linear-gradient(135deg, #FFE5EE 0%, #FFF0E5 100%);
  color: #FF6B9D;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
}

.actions {
  display: flex;
  gap: 20rpx;
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 50rpx;
  font-size: 30rpx;
  background: #f5f5f5;
  color: #333;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA06B 100%);
  color: #fff;
}

.bottom-actions {
  padding: 20rpx;
  margin-top: 20rpx;
}

.loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #FF6B9D;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}
