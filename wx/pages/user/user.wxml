<view class="container">
  <view class="profile-header">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
    <view class="member-badge {{isMember ? 'vip' : ''}}">
      {{isMember ? '👑 会员用户' : '普通用户'}}
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-item" bindtap="goHistory">
      <view class="stat-num">{{stats.totalGenerated || 0}}</view>
      <view class="stat-label">已生成</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goCollection">
      <view class="stat-num">{{stats.totalCollected || 0}}</view>
      <view class="stat-label">已收藏</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{stats.todayRemaining || 0}}</view>
      <view class="stat-label">今日剩余</view>
    </view>
  </view>

  <view class="section-card">
    <view class="menu-item" bindtap="goHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">生成历史</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goCollection">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMember">
      <text class="menu-icon">👑</text>
      <text class="menu-text">{{isMember ? '会员到期：' + expireDate : '开通会员'}}</text>
      <text class="menu-arrow vip-text">{{isMember ? '' : '立即开通 ›'}}</text>
    </view>
  </view>

  <view class="section-card">
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-wrap">
    <button class="btn-logout" bindtap="logout">退出登录</button>
  </view>
</view>
