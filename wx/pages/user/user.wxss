.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.profile-header {
  background: linear-gradient(135deg, #FF6B9D 0%, #FFA06B 100%);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.6);
  margin-bottom: 20rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

.nickname {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.member-badge {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.2);
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.member-badge.vip {
  background: rgba(255,215,0,0.3);
  color: #FFD700;
}

.stats-row {
  background: #fff;
  display: flex;
  align-items: center;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #FF6B9D;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.section-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.vip-text {
  color: #FF6B9D;
  font-size: 26rpx;
}

.logout-wrap {
  margin: 20rpx;
}

.btn-logout {
  background: #fff;
  color: #ff4d4f;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border: 2rpx solid #ffccc7;
}
