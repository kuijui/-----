.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: center;
  padding: 0 60rpx;
}

.go-btn {
  width: 240rpx;
  padding: 0;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border: none;
  box-sizing: border-box;
}

.list {
  padding: 16rpx;
}

.collection-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.topic {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-badge {
  font-size: 24rpx;
  color: #FF6B9D;
  background: #fff5f8;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.card-preview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.style-tag {
  font-size: 22rpx;
  color: #FF6B9D;
  background: #fff0f5;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.collected-time {
  font-size: 22rpx;
  color: #bbb;
  flex: 1;
}

.uncollect {
  font-size: 22rpx;
  color: #ff4d4f;
  padding: 4rpx 14rpx;
  border: 1rpx solid #ffccc7;
  border-radius: 12rpx;
}

.loading-more, .no-more {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  padding: 20rpx 0 10rpx;
}
