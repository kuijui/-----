<view class="tab-bar">
  <view
    wx:for="{{tabs}}"
    wx:key="path"
    class="tab-item {{selected === item.path ? 'active' : ''}}"
    bindtap="switchTab"
    data-path="{{item.path}}"
  >
    <view class="tab-icon">{{item.icon}}</view>
    <view class="tab-label">{{item.label}}</view>
  </view>
</view>
